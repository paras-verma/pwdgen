    "@testing-library/svelte": "5.4.2",
    "@tsconfig/svelte": "5.0.8",
    "@types/qrcode": "1.5.6",
    "jsdom": "29.1.1",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vite": "6.4.3",
    "vitest": "4.1.9"
  },
